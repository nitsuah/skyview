{
  "name": "skyview",
  "version": "1.0.0",
  "description": "A stunning, high-tech website for professional drone services featuring a minimalist design with full-bleed photography, dark high-contrast aesthetics, and glassmorphic UI elements.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:unit": "vitest run --config config/vitest.config.ts",
    "lint:js": "eslint . --config config/eslint.config.mjs",
    "lint:css": "stylelint \"**/*.css\" --config config/stylelint.config.mjs",
    "optimize:images": "node scripts/convert-to-webp.js",
    "serve": "npx http-server . -p 8080"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitsuah/skyview.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/nitsuah/skyview/issues"
  },
  "homepage": "https://github.com/nitsuah/skyview#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "sharp": "^0.35.1"
  }
}